# ================================================================
# Vega Backend 환경변수 키 목록
# 위치: backend/.env.example
# 용도: 신규 개발 환경 세팅 가이드 (실제 값 없음, git 포함)
# 사용: cp .env.example .env → 실제 값으로 채우기
# ================================================================

# ── Supabase ──
# Supabase 대시보드 > Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJ...anon_key_here
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key_here

# ── Groq (무료 티어, OpenAI 호환 REST) ── LLM 채팅·리서치만
# https://console.groq.com/keys — Grok(xAI) 과 별개 서비스이며, 키 접두어는 보통 gsk_ 입니다.
GROQ_API_KEY=gsk_...key_here
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# ── 로컬 임베딩 (sentence-transformers) ── 무료 · Groq는 임베딩 API 없음
# Hugging Face 모델 ID; 기본값은 한국어·다국어에 무난한 mpnet 기반 모델
LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2

# ── 관리자 인증 ──
# X-Admin-Token 헤더 검증용. 최소 32자 랜덤 문자열 권장.
# 생성 예시: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET_TOKEN=your-very-long-random-admin-token-here

# ── 앱 설정 ──
# development | production
ENVIRONMENT=development
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# CORS 허용 Origin (쉼표 구분)
CORS_ORIGINS=http://localhost:3000
